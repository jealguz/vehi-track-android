<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_modal_redondeado">

    <TextView
        android:id="@+id/tvTituloModal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Actualizar Fecha"
        android:textAlignment="center"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#0A2351" />

    <CalendarView
        android:id="@+id/calendarViewModal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp" />

    <Button
        android:id="@+id/btnGuardarFecha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:backgroundTint="#0A2351"
        android:text="GUARDAR CAMBIOS"
        android:textColor="@android:color/white" />

</LinearLayout>